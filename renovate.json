{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":disableRateLimiting"
	],
	"rangeStrategy": "pin",
	"minimumReleaseAge": "3 days",
	"packageRules": [
		{
			"matchPackageNames": [
				"@actual-app/api"
			],
			"minimumReleaseAge": "0 days",
			"automerge": true,
			"platformAutomerge": true
		}
	]
}
