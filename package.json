{
	"name": "fintual-api",
	"packageManager": "pnpm@11.5.1",
	"type": "module",
	"devDependencies": {
		"@types/mailparser": "3.4.6",
		"@types/node": "24.12.4",
		"fallow": "2.88.2",
		"oxfmt": "0.53.0",
		"oxlint": "1.68.0",
		"typescript": "6.0.3"
	},
	"dependencies": {
		"@actual-app/api": "26.6.0",
		"dotenv": "17.4.2",
		"effect": "3.21.2",
		"imapflow": "1.3.5",
		"mailparser": "3.9.9",
		"valibot": "1.4.1"
	},
	"scripts": {
		"typecheck": "tsc -p tsconfig.json",
		"format": "oxfmt --write src",
		"format:check": "oxfmt --check src",
		"lint": "oxlint src",
		"lint:fix": "oxlint --fix src",
		"fallow": "fallow --fail-on-regression",
		"dev": "node src/once.ts",
		"once": "node src/once.ts",
		"capture:har": "sh bin/capture-fintual-har.sh"
	}
}
