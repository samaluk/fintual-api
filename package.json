{
	"name": "fintual-api",
	"packageManager": "pnpm@11.10.0",
	"type": "module",
	"devDependencies": {
		"@types/mailparser": "3.4.6",
		"@types/node": "24.13.2",
		"fallow": "3.0.0",
		"oxfmt": "0.57.0",
		"oxlint": "1.72.0",
		"typescript": "6.0.3"
	},
	"dependencies": {
		"@actual-app/api": "26.7.0",
		"dotenv": "17.4.2",
		"effect": "3.21.4",
		"imapflow": "1.4.3",
		"mailparser": "3.9.14",
		"valibot": "1.4.2"
	},
	"scripts": {
		"typecheck": "tsc -p tsconfig.json",
		"format": "oxfmt --write src",
		"format:check": "oxfmt --check src",
		"lint": "oxlint src",
		"lint:fix": "oxlint --fix src",
		"fallow": "fallow --fail-on-regression",
		"dev": "node src/once.ts",
		"once": "node src/once.ts",
		"capture:har": "sh bin/capture-fintual-har.sh"
	}
}
