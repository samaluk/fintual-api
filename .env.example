# Actual Budget
ACTUAL_SERVER_URL=
ACTUAL_PASSWORD=
ACTUAL_SYNC_ID=
ACTUAL_PAYEE=Fintual
ACTUAL_FINTUAL_ACCOUNT=
# Date from which to start syncing transactions in YYYY-MM-DD format
ACTUAL_STARTING_DATE=2024-03-01

# Fintual
FINTUAL_USER_EMAIL=
FINTUAL_USER_PASSWORD=
# Goal ID from the Fintual goal URL
FINTUAL_GOAL_ID=

# Gmail OAuth for automatic 2FA retrieval
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=
# One-time OAuth bootstrap callback used by `pnpm gmail:token`
GMAIL_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/oauth2/callback
# Optional bind host when running the Gmail OAuth callback listener inside Docker
GMAIL_OAUTH_BIND_HOST=
# Set to false to avoid trying to auto-open a browser from non-GUI environments
GMAIL_OAUTH_OPEN_BROWSER=true

# Optional Fintual 2FA email filters
FINTUAL_2FA_SENDER=notificaciones@fintual.com
FINTUAL_2FA_SUBJECT=Código para entrar
